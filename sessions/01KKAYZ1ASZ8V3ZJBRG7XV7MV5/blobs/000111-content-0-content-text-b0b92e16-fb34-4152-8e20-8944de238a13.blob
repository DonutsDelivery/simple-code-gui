```
     1→import { ipcMain, BrowserWindow, dialog } from 'electron'
     2→import { existsSync, mkdirSync, writeFileSync, readFileSync } from 'fs'
     3→import { join } from 'path'
     4→import { voiceManager, WHISPER_MODELS, PIPER_VOICES, WhisperModelName, PiperVoiceName } from '../voice-manager'
     5→import { xttsManager, XTTS_LANGUAGES, XTTS_SAMPLE_VOICES } from '../xtts-manager'
     6→
     7→const TTS_INSTRUCTIONS_START = '\n\n<!-- TTS_VOICE_OUTPUT_START -->'
     8→const TTS_INSTRUCTIONS_END = '<!-- TTS_VOICE_OUTPUT_END -->\n'
     9→const TTS_INSTRUCTIONS = `${TTS_INSTRUCTIONS_START}
    10→## Voice Output (TTS)
    11→
    12→When responding, wrap your natural language prose in \`«tts»...«/tts»\` markers for text-to-speech.
    13→
    14→Rules:
    15→- ONLY wrap conversational prose meant to be spoken aloud
    16→- Do NOT wrap: code, file paths, commands, tool output, URLs, lists, errors
    17→- Keep markers on same line as text (no line breaks inside)
    18→
    19→Examples:
    20→✓ «tts»I'll help you fix that bug.«/tts»
    21→✓ «tts»The tests are passing.«/tts» Here's what changed:
    22→✗ «tts»src/Header.tsx«/tts»  (file path - don't wrap)
    23→✗ «tts»npm install«/tts»  (command - don't wrap)
    24→${TTS_INSTRUCTIONS_END}`
    25→
    26→function installTTSInstructions(projectPath: string): boolean {
    27→  try {
    28→    const claudeDir = join(projectPath, '.claude')
    29→    const claudeMdPath = join(claudeDir, 'CLAUDE.md')
    30→
    31→    if (!existsSync(claudeDir)) {
    32→      mkdirSync(claudeDir, { recursive: true })
    33→    }
    34→
    35→    let content = ''
    36→    if (existsSync(claudeMdPath)) {
    37→      content = readFileSync(claudeMdPath, 'utf8')
    38→      if (content.includes(TTS_INSTRUCTIONS_START)) {
    39→        const startIdx = content.indexOf(TTS_INSTRUCTIONS_START)
    40→        const endIdx = content.indexOf(TTS_INSTRUCTIONS_END)
    41→        if (startIdx !== -1 && endIdx !== -1) {
    42→          content = content.substring(0, startIdx) + content.substring(endIdx + TTS_INSTRUCTIONS_END.length)
    43→          content += TTS_INSTRUCTIONS
    44→          writeFileSync(claudeMdPath, content)
    45→          return true
    46→        }
    47→      }
    48→    }
    49→
    50→    content += TTS_INSTRUCTIONS
    51→    writeFileSync(claudeMdPath, content)
    52→    return true
    53→  } catch (e) {
    54→    console.error('Failed to install TTS instructions:', e)
    55→    return false
    56→  }
    57→}
    58→
    59→function removeTTSInstructions(projectPath: string): boolean {
    60→  try {
    61→    const claudeMdPath = join(projectPath, '.claude', 'CLAUDE.md')
    62→    if (!existsSync(claudeMdPath)) return true
    63→
    64→    let content = readFileSync(claudeMdPath, 'utf8')
    65→    const startIdx = content.indexOf(TTS_INSTRUCTIONS_START)
    66→    const endIdx = content.indexOf(TTS_INSTRUCTIONS_END)
    67→
    68→    if (startIdx !== -1 && endIdx !== -1) {
    69→      content = content.slice(0, startIdx) + content.slice(endIdx + TTS_INSTRUCTIONS_END.length)
    70→      content = content.trimEnd() + '\n'
    71→      writeFileSync(claudeMdPath, content)
    72→    }
    73→    return true
    74→  } catch (e) {
    75→    console.error('Failed to remove TTS instructions:', e)
    76→    return false
    77→  }
    78→}
    79→
    80→export function registerVoiceHandlers(getMainWindow: () => BrowserWindow | null) {
    81→  // TTS Instructions
    82→  ipcMain.handle('tts:installInstructions', (_, projectPath: string) => {
    83→    return { success: installTTSInstructions(projectPath) }
    84→  })
    85→
    86→  ipcMain.handle('tts:removeInstructions', (_, projectPath: string) => {
    87→    return { success: removeTTSInstructions(projectPath) }
    88→  })
    89→
    90→  // Whisper (STT)
    91→  ipcMain.handle('voice:checkWhisper', async () => {
    92→    try {
    93→      return await voiceManager.checkWhisper()
    94→    } catch (e) {
    95→      return { success: false, error: e instanceof Error ? e.message : String(e) }
    96→    }
    97→  })
    98→
    99→  ipcMain.handle('voice:installWhisper', async (_, model: WhisperModelName) => {
   100→    try {
   101→      return await voiceManager.downloadWhisperModel(model, (status, percent) => {
   102→        getMainWindow()?.webContents.send('install:progress', { type: 'whisper', status, percent })
   103→      })
   104→    } catch (e) {
   105→      return { success: false, error: e instanceof Error ? e.message : String(e) }
   106→    }
   107→  })
   108→
