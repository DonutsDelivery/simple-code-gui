   266→  ipcMain.handle('voice:importCustom', async () => {
   267→    try {
   268→      const win = getMainWindow()
   269→      if (!win) {
   270→        return { success: false, error: 'No window available' }
   271→      }
   272→
   273→      const result = await dialog.showOpenDialog(win, {
   274→        title: 'Select Piper Voice Model',
   275→        filters: [{ name: 'ONNX Model', extensions: ['onnx'] }],
   276→        properties: ['openFile']
   277→      })
   278→
   279→      if (result.canceled || !result.filePaths[0]) {
   280→        return { success: false, error: 'No file selected' }
   281→      }
   282→
   283→      const onnxPath = result.filePaths[0]
   284→      const configPath = onnxPath + '.json'
   285→      if (!existsSync(configPath)) {
   286→        return { success: false, error: 'Config file (.onnx.json) not found next to model file' }
   287→      }
   288→
   289→      return await voiceManager.importCustomVoiceFiles(onnxPath, configPath)
   290→    } catch (e) {
   291→      return { success: false, error: e instanceof Error ? e.message : String(e) }
   292→    }
   293→  })
