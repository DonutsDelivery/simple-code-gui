   181→  ipcMain.handle('voice:getVoices', async () => {
   182→    try {
   183→      const installed = voiceManager.getInstalledPiperVoices()
   184→      const all = Object.entries(PIPER_VOICES).map(([id, info]) => ({
   185→        id,
   186→        description: info.description,
   187→        license: info.license,
   188→        installed: installed.includes(id)
   189→      }))
   190→      return { installed, all }
   191→    } catch (e) {
   192→      return { success: false, error: e instanceof Error ? e.message : String(e) }
   193→    }
   194→  })
   195→
   196→  ipcMain.handle('voice:getWhisperModels', async () => {
   197→    try {
   198→      const installedModels = voiceManager.getInstalledWhisperModels()
   199→      // Cast keys to WhisperModelName - safe since we're iterating over WHISPER_MODELS keys
   200→      const modelIds = Object.keys(WHISPER_MODELS) as WhisperModelName[]
   201→      const all = modelIds.map(id => ({
   202→        id,
   203→        size: WHISPER_MODELS[id].size,
   204→        installed: installedModels.includes(id)
   205→      }))
   206→      return { installed: installedModels, all }
   207→    } catch (e) {
   208→      return { success: false, error: e instanceof Error ? e.message : String(e) }
   209→    }
   210→  })
