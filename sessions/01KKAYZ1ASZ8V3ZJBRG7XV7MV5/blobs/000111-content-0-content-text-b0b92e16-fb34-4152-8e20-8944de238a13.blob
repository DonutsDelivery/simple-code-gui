   431→  ipcMain.handle('xtts:selectMediaFile', async () => {
   432→    try {
   433→      const result = await dialog.showOpenDialog({
   434→        properties: ['openFile'],
   435→        filters: [
   436→          { name: 'Media Files', extensions: ['mp4', 'webm', 'mkv', 'avi', 'mov', 'mp3', 'wav', 'ogg', 'flac', 'm4a'] },
   437→          { name: 'All Files', extensions: ['*'] }
   438→        ]
   439→      })
   440→
   441→      if (result.canceled || result.filePaths.length === 0) {
   442→        return { success: false }
   443→      }
   444→
   445→      const filePath = result.filePaths[0]
   446→      const duration = await xttsManager.getMediaDuration(filePath)
   447→
   448→      return {
   449→        success: true,
   450→        path: filePath,
   451→        duration: duration.success ? duration.duration : undefined,
   452→        error: duration.error
   453→      }
   454→    } catch (e) {
   455→      return { success: false, error: e instanceof Error ? e.message : String(e) }
   456→    }
   457→  })
