   193→
   194→// Find opencode executable - on Windows, npm installs .cmd files
   195→function findOpenCodeExecutable(): string {
   196→  if (!isWindows) {
   197→    return 'opencode'
   198→  }
   199→
   200→  // On Windows, check for opencode.cmd in portable npm-global first
   201→  const portableDirs = getPortableBinDirs()
   202→  for (const dir of portableDirs) {
   203→    const opencodeCmd = path.join(dir, 'opencode.cmd')
   204→    if (fs.existsSync(opencodeCmd)) {
   205→      console.log('Found OpenCode at (portable):', opencodeCmd)
   206→      return opencodeCmd
   207→    }
   208→  }
   209→
   210→  // Then check for opencode.cmd in system npm paths
   211→  const additionalPaths = getAdditionalPaths()
   212→  for (const dir of additionalPaths) {
   213→    const opencodeCmd = path.join(dir, 'opencode.cmd')
   214→    if (fs.existsSync(opencodeCmd)) {
   215→      console.log('Found OpenCode at:', opencodeCmd)
   216→      return opencodeCmd
   217→    }
   218→  }
   219→
   220→  // Fall back to just 'opencode' and let PATH resolve it
   221→  return 'opencode'
   222→}
   223→
   224→// Find claude executable - on Windows, npm installs .cmd files, native installer creates .exe
   225→function findClaudeExecutable(): string {
   226→  if (!isWindows) {
   227→    return 'claude'
   228→  }
   229→
   230→  // Windows: check for both .cmd (npm) and .exe (native) installations
   231→  const extensions = ['claude.cmd', 'claude.exe']
   232→
   233→  // Check portable npm-global first
   234→  const portableDirs = getPortableBinDirs()
   235→  for (const dir of portableDirs) {
   236→    for (const ext of extensions) {
   237→      const claudePath = path.join(dir, ext)
   238→      if (fs.existsSync(claudePath)) {
   239→        console.log('Found Claude at (portable):', claudePath)
   240→        return claudePath
   241→      }
   242→    }
   243→  }
   244→
   245→  // Then check system paths (includes ~/.local/bin for native installs)
   246→  const additionalPaths = getAdditionalPaths()
   247→  for (const dir of additionalPaths) {
   248→    for (const ext of extensions) {
   249→      const claudePath = path.join(dir, ext)
   250→      if (fs.existsSync(claudePath)) {
   251→        console.log('Found Claude at:', claudePath)
   252→        return claudePath
   253→      }
   254→    }
   255→  }
   256→
   257→  // Fall back to just 'claude' and let PATH resolve it
   258→  return 'claude'
   259→}
   260→
   261→// Find aider executable - pip installs to Scripts on Windows, bin on Unix
   262→function findAiderExecutable(): string {
   263→  if (!isWindows) {
   264→    return 'aider'
   265→  }
   266→
   267→  // On Windows, check for aider.exe in portable Python Scripts first
   268→  const portableDirs = getPortableBinDirs()
   269→  for (const dir of portableDirs) {
   270→    // pip installs to Scripts directory on Windows
   271→    const aiderExe = path.join(dir, 'aider.exe')
   272→    if (fs.existsSync(aiderExe)) {
   273→      console.log('Found Aider at (portable):', aiderExe)
   274→      return aiderExe
   275→    }
   276→    // Also check parent/Scripts (if dir is the node bin)
   277→    const scriptsDir = path.join(path.dirname(dir), 'Scripts')
   278→    const aiderInScripts = path.join(scriptsDir, 'aider.exe')
   279→    if (fs.existsSync(aiderInScripts)) {
   280→      console.log('Found Aider at (Scripts):', aiderInScripts)
   281→      return aiderInScripts
   282→    }
   283→  }
   284→
   285→  // Check common Python Scripts locations
   286→  const pythonPaths = [
   287→    path.join(
   288→      process.env.LOCALAPPDATA || '',
   289→      'Programs',
   290→      'Python',
   291→      'Python312',
   292→      'Scripts'
   293→    ),
   294→    path.join(
   295→      process.env.LOCALAPPDATA || '',
   296→      'Programs',
   297→      'Python',
   298→      'Python311',
   299→      'Scripts'
   300→    ),
   301→    path.join(process.env.APPDATA || '', 'Python', 'Python312', 'Scripts'),
   302→    path.join(process.env.APPDATA || '', 'Python', 'Python311', 'Scripts'),
   303→  ]
   304→  for (const dir of pythonPaths) {
   305→    const aiderExe = path.join(dir, 'aider.exe')
   306→    if (fs.existsSync(aiderExe)) {
   307→      console.log('Found Aider at:', aiderExe)
   308→      return aiderExe
   309→    }
   310→  }
   311→
   312→  // Fall back to just 'aider' and let PATH resolve it
   313→  return 'aider'
   314→}
