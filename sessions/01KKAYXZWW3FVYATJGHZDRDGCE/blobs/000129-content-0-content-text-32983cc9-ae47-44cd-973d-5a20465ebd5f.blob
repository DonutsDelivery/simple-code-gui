     1→import * as pty from 'node-pty'
     2→import * as fs from 'fs'
     3→import * as path from 'path'
     4→import {
     5→  isWindows,
     6→  getEnhancedPathWithPortable,
     7→  getAdditionalPaths,
     8→} from './platform'
     9→import { getPortableBinDirs } from './portable-deps'
    10→
    11→// Backends that use Ink (React for CLI) and are sensitive to rapid resize during startup
    12→const INK_BACKENDS = new Set(['gemini'])
    13→
    14→// Ring buffer for storing recent PTY output
    15→const OUTPUT_BUFFER_MAX_LINES = 200
    16→
    17→class OutputBuffer {
    18→  private lines: string[] = []
    19→  private partial: string = '' // incomplete line (no newline yet)
    20→
    21→  append(data: string): void {
    22→    // Split incoming data by newlines, preserving partial lines
    23→    const text = this.partial + data
    24→    const parts = text.split('\n')
    25→    // Last element is either empty (if data ended with \n) or a partial line
    26→    this.partial = parts.pop() || ''
    27→    for (const line of parts) {
    28→      // Strip ANSI escape sequences for readability
    29→      // Strip all CSI sequences (including private modes like ?25h, ?1049h),
    30→      // OSC sequences, and single-character escape sequences (e.g. \x1b(B)
    31→      const clean = line
    32→        .replace(/\x1b\[[\x20-\x3f]*[\x40-\x7e]/g, '')  // CSI: covers standard + private mode sequences
    33→        .replace(/\x1b\][^\x07\x1b]*(?:\x07|\x1b\\)/g, '')  // OSC: terminated by BEL or ST
    34→        .replace(/\x1b[()][A-Z0-9]/g, '')  // Character set selection (e.g. \x1b(B)
    35→        .trim()
    36→      if (clean) {
    37→        this.lines.push(clean)
    38→        if (this.lines.length > OUTPUT_BUFFER_MAX_LINES) {
    39→          this.lines.shift()
    40→        }
    41→      }
    42→    }
    43→  }
    44→
    45→  getRecent(maxLines: number = 50): string[] {
    46→    return this.lines.slice(-maxLines)
    47→  }
    48→
    49→  clear(): void {
    50→    this.lines = []
    51→    this.partial = ''
    52→  }
    53→}
    54→
    55→interface ClaudeProcess {
    56→  id: string
    57→  pty: pty.IPty
    58→  cwd: string
    59→  sessionId?: string
    60→  backend?: 'claude' | 'gemini' | 'codex' | 'opencode' | 'aider'
    61→  disposables: { dispose: () => void }[]
    62→  spawnedAt: number
    63→  resizeTimeout?: ReturnType<typeof setTimeout>
    64→  lastResizeCols?: number
    65→  lastResizeRows?: number
    66→  outputBuffer: OutputBuffer
    67→}
    68→
    69→// Extended node-pty options - useConpty is a Windows-specific option not in @types/node-pty
    70→interface ExtendedPtyForkOptions extends pty.IPtyForkOptions {
    71→  useConpty?: boolean
    72→}
    73→
    74→function getEnhancedEnv(): { [key: string]: string } {
    75→  const env = { ...process.env } as { [key: string]: string }
    76→  delete env.CLAUDECODE
    77→  const enhancedPath = getEnhancedPathWithPortable()
    78→
    79→  // On Windows, environment variables are case-insensitive but we need to set the right one
    80→  if (isWindows) {
    81→    // Windows uses 'Path' but Node sometimes uses 'PATH' - set both to be safe
    82→    env.PATH = enhancedPath
    83→    env.Path = enhancedPath
    84→
    85→    // Claude Code on Windows requires git-bash - try to find and set it
    86→    if (!env.CLAUDE_CODE_GIT_BASH_PATH) {
    87→      const gitBashPaths = [
    88→        'C:\\Program Files\\Git\\bin\\bash.exe',
    89→        'C:\\Program Files (x86)\\Git\\bin\\bash.exe',
    90→        path.join(
    91→          process.env.LOCALAPPDATA || '',
    92→          'Programs',
    93→          'Git',
    94→          'bin',
    95→          'bash.exe'
    96→        ),
    97→        path.join(process.env.PROGRAMFILES || '', 'Git', 'bin', 'bash.exe'),
    98→      ]
    99→      for (const bashPath of gitBashPaths) {
   100→        if (fs.existsSync(bashPath)) {
   101→          env.CLAUDE_CODE_GIT_BASH_PATH = bashPath
   102→          console.log('Found git-bash at:', bashPath)
   103→          break
   104→        }
   105→      }
   106→    }
   107→  } else {
   108→    env.PATH = enhancedPath
   109→  }
   110→
   111→  console.log('Enhanced PATH for PTY:', enhancedPath.substring(0, 200) + '...')
   112→  return env
   113→}
   114→
   115→// Find executable for the given backend
   116→function findExecutable(
   117→  backend: 'claude' | 'gemini' | 'codex' | 'opencode' | 'aider' = 'claude'
   118→): string {
   119→  if (backend === 'gemini') {
   120→    return findGeminiExecutable()
   121→  }
   122→  if (backend === 'codex') {
   123→    return findCodexExecutable()
   124→  }
   125→  if (backend === 'opencode') {
   126→    return findOpenCodeExecutable()
   127→  }
   128→  if (backend === 'aider') {
   129→    return findAiderExecutable()
   130→  }
   131→  return findClaudeExecutable()
   132→}
   133→
   134→// Find gemini executable - on Windows, npm installs .cmd files
   135→function findGeminiExecutable(): string {
   136→  if (!isWindows) {
   137→    return 'gemini'
   138→  }
   139→
   140→  // On Windows, check for gemini.cmd in portable npm-global first
   141→  const portableDirs = getPortableBinDirs()
   142→  for (const dir of portableDirs) {
   143→    const geminiCmd = path.join(dir, 'gemini.cmd')
   144→    if (fs.existsSync(geminiCmd)) {
   145→      console.log('Found Gemini at (portable):', geminiCmd)
   146→      return geminiCmd
   147→    }
   148→  }
   149→
   150→  // Then check for gemini.cmd in system npm paths
   151→  const additionalPaths = getAdditionalPaths()
   152→  for (const dir of additionalPaths) {
   153→    const geminiCmd = path.join(dir, 'gemini.cmd')
   154→    if (fs.existsSync(geminiCmd)) {
   155→      console.log('Found Gemini at:', geminiCmd)
   156→      return geminiCmd
   157→    }
   158→  }
   159→
   160→  // Fall back to just 'gemini' and let PATH resolve it
   161→  return 'gemini'
   162→}
   163→
   164→// Find codex executable - on Windows, npm installs .cmd files
   165→function findCodexExecutable(): string {
   166→  if (!isWindows) {
   167→    return 'codex'
   168→  }
   169→
   170→  // On Windows, check for codex.cmd in portable npm-global first
   171→  const portableDirs = getPortableBinDirs()
   172→  for (const dir of portableDirs) {
   173→    const codexCmd = path.join(dir, 'codex.cmd')
   174→    if (fs.existsSync(codexCmd)) {
   175→      console.log('Found Codex at (portable):', codexCmd)
   176→      return codexCmd
   177→    }
   178→  }
   179→
   180→  // Then check for codex.cmd in system npm paths
   181→  const additionalPaths = getAdditionalPaths()
   182→  for (const dir of additionalPaths) {
   183→    const codexCmd = path.join(dir, 'codex.cmd')
   184→    if (fs.existsSync(codexCmd)) {
   185→      console.log('Found Codex at:', codexCmd)
   186→      return codexCmd
   187→    }
   188→  }
   189→
   190→  // Fall back to just 'codex' and let PATH resolve it
   191→  return 'codex'
