   316→// Build backend-specific permission arguments
   317→// Maps our internal permission modes to each backend's CLI flags
   318→function buildPermissionArgs(
   319→  backend: 'claude' | 'gemini' | 'codex' | 'opencode' | 'aider' = 'claude',
   320→  permissionMode?: string,
   321→  autoAcceptTools?: string[]
   322→): string[] {
   323→  const args: string[] = []
   324→
   325→  switch (backend) {
   326→    case 'claude':
   327→      // Claude Code: --permission-mode and --allowedTools
   328→      if (permissionMode && permissionMode !== 'default') {
   329→        args.push('--permission-mode', permissionMode)
   330→      }
   331→      if (autoAcceptTools && autoAcceptTools.length > 0) {
   332→        for (const tool of autoAcceptTools) {
   333→          args.push('--allowedTools', tool)
   334→        }
   335→      }
   336→      break
   337→
   338→    case 'gemini':
   339→      // Gemini CLI: --approval-mode (default/auto_edit/yolo) and --allowed-tools
   340→      // See: https://geminicli.com/docs/get-started/configuration/
   341→      if (permissionMode) {
   342→        switch (permissionMode) {
   343→          case 'acceptEdits':
   344→            args.push('--approval-mode', 'auto_edit')
   345→            break
   346→          case 'dontAsk':
   347→          case 'bypassPermissions':
   348→            args.push('--approval-mode', 'yolo')
   349→            break
   350→          // 'default' mode = no flag needed
   351→        }
   352→      }
   353→      if (autoAcceptTools && autoAcceptTools.length > 0) {
   354→        // Gemini uses comma-separated list for --allowed-tools
   355→        args.push('--allowed-tools', autoAcceptTools.join(','))
   356→      }
   357→      break
   358→
   359→    case 'codex':
   360→      // Codex CLI: --full-auto or --dangerously-bypass-approvals-and-sandbox
   361→      // See: https://developers.openai.com/codex/cli/reference/
   362→      if (permissionMode) {
   363→        switch (permissionMode) {
   364→          case 'acceptEdits':
   365→          case 'dontAsk':
   366→            args.push('--full-auto')
   367→            break
   368→          case 'bypassPermissions':
   369→            args.push('--dangerously-bypass-approvals-and-sandbox')
   370→            break
   371→          // 'default' mode = no flag needed
   372→        }
   373→      }
   374→      // Codex doesn't support per-tool auto-accept via CLI flags
   375→      break
   376→
   377→    case 'opencode':
   378→      // OpenCode doesn't accept permission flags on the CLI (use config instead).
   379→      // Ignore auto-accept tools to avoid invalid arguments.
   380→      break
   381→
   382→    case 'aider':
   383→      // Aider doesn't have permission flags - it uses --yes for auto-confirm
   384→      if (permissionMode && permissionMode !== 'default') {
   385→        args.push('--yes')
   386→      }
   387→      break
   388→  }
   389→
   390→  return args
   391→}
   392→
   393→function buildResumeArgs(
   394→  backend: string = 'claude',
   395→  sessionId?: string
   396→): string[] {
   397→  if (!sessionId) {
   398→    return []
   399→  }
   400→  switch (backend) {
   401→    case 'gemini':
   402→      return ['--resume', sessionId]
   403→    case 'codex':
   404→      return ['--resume', sessionId]
   405→    case 'opencode':
   406→      return ['--session', sessionId]
   407→    case 'aider':
   408→      return ['--restore', sessionId]
   409→    case 'claude':
   410→    default:
   411→      return ['-r', sessionId]
   412→  }
   413→}
   414→
   415→export class PtyManager {
   416→  private processes: Map<string, ClaudeProcess> = new Map()
   417→  private dataCallbacks: Map<string, (data: string) => void> = new Map()
   418→  private exitCallbacks: Map<string, (code: number) => void> = new Map()
   419→
   420→  spawn(
   421→    cwd: string,
   422→    sessionId?: string,
   423→    autoAcceptTools?: string[],
   424→    permissionMode?: string,
   425→    model?: string,
   426→    backend?: 'claude' | 'gemini' | 'codex' | 'opencode' | 'aider'
   427→  ): string {
   428→    const id = crypto.randomUUID()
   429→
   430→    const args: string[] = []
   431→    args.push(...buildResumeArgs(backend || 'claude', sessionId))
   432→
   433→    // Add model if specified (and not default)
   434→    if (model && model !== 'default') {
   435→      args.push('--model', model)
   436→    }
   437→
   438→    // Add backend-specific permission arguments
   439→    const permissionArgs = buildPermissionArgs(
   440→      backend || 'claude',
   441→      permissionMode,
   442→      autoAcceptTools
   443→    )
   444→    args.push(...permissionArgs)
   445→
   446→    const exe = findExecutable(backend)
   447→    console.log('Spawning', backend, ':', exe, 'in', cwd, 'with args:', args)
   448→
   449→    const ptyOptions: ExtendedPtyForkOptions = {
   450→      name: 'xterm-256color',
   451→      cols: 120,
   452→      rows: 30,
   453→      cwd,
   454→      env: getEnhancedEnv(),
   455→      handleFlowControl: true, // Enable XON/XOFF flow control for better backpressure handling
   456→    }
   457→
   458→    // Windows: use ConPTY for better escape sequence and UTF-8 handling
   459→    if (isWindows) {
   460→      ptyOptions.useConpty = true
   461→    }
   462→
   463→    const shell = pty.spawn(exe, args, ptyOptions)
   464→
   465→    const proc: ClaudeProcess = {
   466→      id,
   467→      pty: shell,
   468→      cwd,
   469→      sessionId,
   470→      backend: backend as
   471→        | 'claude'
   472→        | 'gemini'
   473→        | 'codex'
   474→        | 'opencode'
   475→        | 'aider'
   476→        | undefined,
   477→      disposables: [],
   478→      spawnedAt: Date.now(),
   479→      outputBuffer: new OutputBuffer(),
   480→    }
   481→
   482→    this.processes.set(id, proc)
   483→
   484→    // Store disposables from onData/onExit for proper cleanup
   485→    const dataDisposable = shell.onData(data => {
   486→      proc.outputBuffer.append(data)
   487→      const callback = this.dataCallbacks.get(id)
   488→      if (callback) {
   489→        callback(data)
   490→      }
   491→    })
   492→    proc.disposables.push(dataDisposable)
   493→
   494→    const exitDisposable = shell.onExit(({ exitCode }) => {
   495→      const callback = this.exitCallbacks.get(id)
   496→      if (callback) {
   497→        callback(exitCode)
   498→      }
   499→      this.cleanupProcess(id)
   500→    })
   501→    proc.disposables.push(exitDisposable)
   502→
   503→    return id
   504→  }
   505→
   506→  write(id: string, data: string): void {
   507→    const proc = this.processes.get(id)
   508→    if (proc) {
   509→      proc.pty.write(data)
   510→    }
   511→  }
   512→
   513→  resize(id: string, cols: number, rows: number): void {
   514→    const proc = this.processes.get(id)
   515→    if (!proc) return
   516→
   517→    // Skip if dimensions haven't changed
   518→    if (proc.lastResizeCols === cols && proc.lastResizeRows === rows) return
   519→
   520→    // Debounce resize events - Ink-based CLIs (e.g. Gemini) crash with
   521→    // infinite re-render loops when they receive rapid SIGWINCH during startup
   522→    if (proc.resizeTimeout) {
   523→      clearTimeout(proc.resizeTimeout)
   524→    }
   525→
   526→    const elapsed = Date.now() - proc.spawnedAt
   527→    const isInkBackend = INK_BACKENDS.has(proc.backend || '')
   528→    // During first 5s of Ink-backend startup, coalesce resizes with 1.5s debounce
   529→    // to let the CLI finish initialization before sending SIGWINCH
   530→    const debounceMs = isInkBackend && elapsed < 5000 ? 1500 : 50
   531→
   532→    proc.resizeTimeout = setTimeout(() => {
   533→      proc.resizeTimeout = undefined
   534→      proc.lastResizeCols = cols
   535→      proc.lastResizeRows = rows
   536→      try {
   537→        proc.pty.resize(cols, rows)
   538→      } catch (e) {
   539→        // PTY may have already exited, ignore resize errors
   540→        console.log('PTY resize ignored (may have exited):', id)
   541→      }
   542→    }, debounceMs)
   543→  }
   544→
   545→  private cleanupProcess(id: string): void {
   546→    const proc = this.processes.get(id)
   547→    if (proc) {
   548→      // Clear pending resize debounce
   549→      if (proc.resizeTimeout) {
   550→        clearTimeout(proc.resizeTimeout)
   551→        proc.resizeTimeout = undefined
   552→      }
   553→      // Dispose all event listeners first
   554→      for (const disposable of proc.disposables) {
   555→        try {
   556→          disposable.dispose()
   557→        } catch (e) {
   558→          // Ignore dispose errors
   559→        }
   560→      }
   561→      proc.disposables.length = 0
   562→    }
   563→    this.processes.delete(id)
   564→    this.dataCallbacks.delete(id)
   565→    this.exitCallbacks.delete(id)
   566→  }
   567→
   568→  kill(id: string): void {
   569→    const proc = this.processes.get(id)
   570→    if (proc) {
   571→      try {
   572→        // Windows doesn't support SIGKILL, use default signal
   573→        if (isWindows) {
   574→          proc.pty.kill()
   575→        } else {
   576→          proc.pty.kill('SIGKILL')
   577→        }
   578→      } catch (e) {
   579→        // Process may already be dead
   580→      }
   581→      this.cleanupProcess(id)
   582→    }
   583→  }
   584→
   585→  killAll(): void {
   586→    console.log(`Killing ${this.processes.size} PTY processes`)
   587→    for (const [id] of this.processes) {
   588→      this.kill(id)
   589→    }
   590→    this.processes.clear()
   591→  }
   592→
   593→  getProcess(id: string): ClaudeProcess | undefined {
   594→    return this.processes.get(id)
   595→  }
   596→
   597→  onData(id: string, callback: (data: string) => void): void {
   598→    this.dataCallbacks.set(id, callback)
   599→  }
   600→
   601→  onExit(id: string, callback: (code: number) => void): void {
   602→    this.exitCallbacks.set(id, callback)
   603→  }
   604→
   605→  // Orchestrator API: list all active sessions
   606→  listSessions(): Array<{ id: string; cwd: string; backend: string; sessionId?: string; spawnedAt: number }> {
   607→    const sessions: Array<{ id: string; cwd: string; backend: string; sessionId?: string; spawnedAt: number }> = []
   608→    for (const [id, proc] of this.processes) {
   609→      sessions.push({
   610→        id,
   611→        cwd: proc.cwd,
   612→        backend: proc.backend || 'claude',
   613→        sessionId: proc.sessionId,
   614→        spawnedAt: proc.spawnedAt,
   615→      })
   616→    }
   617→    return sessions
   618→  }
   619→
   620→  // Orchestrator API: read recent output from a PTY
   621→  readOutput(id: string, maxLines: number = 50): string[] | null {
   622→    const proc = this.processes.get(id)
   623→    if (!proc) return null
   624→    return proc.outputBuffer.getRecent(maxLines)
   625→  }
   626→}
   627→
