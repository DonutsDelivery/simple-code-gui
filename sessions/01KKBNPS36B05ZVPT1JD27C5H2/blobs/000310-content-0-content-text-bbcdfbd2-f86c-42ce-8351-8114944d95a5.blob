    42→@@ -80,13 +80,24 @@ export function registerPtyHandlers(
    43→         pendingApiPrompts.delete(cwd)
    44→         if (pending.autoClose) autoCloseSessions.add(id)
    45→         setTimeout(() => {
    46→-          ptyManager.write(id, pending.prompt + '\n')
    47→-          pending.resolve({ success: true, message: 'Prompt sent to new terminal', sessionCreated: true })
    48→+          // Verify PTY still exists before writing (race condition guard)
    49→+          if (ptyManager.getProcess(id)) {
    50→+            ptyManager.write(id, pending.prompt + '\n')
    51→+            pending.resolve({ success: true, message: 'Prompt sent to new terminal', sessionCreated: true })
    52→+          } else {
    53→+            pending.resolve({ success: false, error: 'Terminal exited before prompt could be sent' })
    54→+          }
    55→         }, 4000)
    56→       }
    57→ 
    58→       return id
    59→     } catch (error: any) {
    60→+      // Resolve pending prompt immediately on spawn failure instead of waiting for 30s timeout
    61→+      const pending = pendingApiPrompts.get(cwd)
    62→+      if (pending) {
    63→+        pendingApiPrompts.delete(cwd)
    64→+        pending.resolve({ success: false, error: `Failed to start terminal: ${error.message}` })
    65→+      }
    66→       console.error('Failed to spawn PTY:', error)
    67→       throw new Error(`Failed to start Claude: ${error.message}`)
    68→     }
