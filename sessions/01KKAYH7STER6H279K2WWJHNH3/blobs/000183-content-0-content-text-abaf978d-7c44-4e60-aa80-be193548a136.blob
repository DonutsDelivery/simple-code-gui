   403→
   404→// =============================================================================
   405→// Factory Functions
   406→// =============================================================================
   407→
   408→/**
   409→ * Check if running in Electron environment with electronAPI available
   410→ */
   411→export function isElectronEnvironment(): boolean {
   412→  return typeof window !== 'undefined' && 'electronAPI' in window
   413→}
   414→
   415→/**
   416→ * Get the electronAPI if available
   417→ */
   418→export function getElectronAPI(): unknown | null {
   419→  if (isElectronEnvironment()) {
   420→    return (window as unknown as Record<string, unknown>).electronAPI
   421→  }
   422→  return null
   423→}
   424→
   425→// Singleton HTTP client instance
   426→let httpClientInstance: HttpApiClient | null = null
   427→
   428→/**
   429→ * Create or get an API client
   430→ *
   431→ * - If running in Electron, returns electronAPI
   432→ * - If hostConfig is provided, creates/returns HttpApiClient
   433→ * - Returns null if neither is available
   434→ */
   435→export function createApiClient(hostConfig?: HostConfig): HttpApiClient | unknown | null {
   436→  // Check for Electron first
   437→  const electronAPI = getElectronAPI()
   438→  if (electronAPI && !hostConfig) {
   439→    return electronAPI
   440→  }
   441→
   442→  // Create HTTP client if config provided
   443→  if (hostConfig) {
   444→    httpClientInstance = new HttpApiClient(hostConfig)
   445→    return httpClientInstance
   446→  }
   447→
   448→  // Return existing HTTP client if available
   449→  if (httpClientInstance) {
   450→    return httpClientInstance
   451→  }
   452→
   453→  return null
   454→}
   455→
   456→/**
   457→ * Get the current API client instance
   458→ */
   459→export function getApiClient(): HttpApiClient | unknown | null {
   460→  const electronAPI = getElectronAPI()
   461→  if (electronAPI) {
   462→    return electronAPI
   463→  }
   464→  return httpClientInstance
   465→}
   466→
   467→/**
   468→ * Set the HTTP client instance (for testing or manual configuration)
   469→ */
   470→export function setHttpClient(client: HttpApiClient | null): void {
   471→  httpClientInstance = client
   472→}
   473→
