    26→export * from './types.js'
    27→
    28→// =============================================================================
    29→// HTTP API Client Class
    30→// =============================================================================
    31→
    32→export class HttpApiClient {
    33→  private config: HostConfig
    34→  private wsManager: WebSocketManager
    35→
    36→  constructor(config: HostConfig) {
    37→    this.config = config
    38→    this.wsManager = new WebSocketManager(config)
    39→  }
    40→
    41→  // ===========================================================================
    42→  // Connection Management
    43→  // ===========================================================================
    44→
    45→  async connect(): Promise<void> {
    46→    await this.wsManager.connect()
    47→  }
    48→
    49→  disconnect(): void {
    50→    this.wsManager.disconnect()
    51→  }
    52→
    53→  isConnected(): boolean {
    54→    return this.wsManager.isConnected()
    55→  }
    56→
    57→  onConnect(callback: () => void): () => void {
    58→    return this.wsManager.onConnect(callback)
    59→  }
    60→
    61→  onDisconnect(callback: () => void): () => void {
    62→    return this.wsManager.onDisconnect(callback)
    63→  }
    64→
    65→  // ===========================================================================
    66→  // Workspace API
    67→  // ===========================================================================
    68→
    69→  getWorkspace(): Promise<Workspace> {
    70→    return workspace.getWorkspace(this.config)
    71→  }
    72→
    73→  saveWorkspace(ws: Workspace): Promise<void> {
    74→    return workspace.saveWorkspace(this.config, ws)
    75→  }
    76→
    77→  addProject(): Promise<string | null> {
    78→    return misc.addProject()
    79→  }
    80→
    81→  // ===========================================================================
    82→  // Sessions API
    83→  // ===========================================================================
    84→
    85→  discoverSessions(projectPath: string, backend?: BackendId): Promise<Session[]> {
    86→    return workspace.discoverSessions(this.config, projectPath, backend)
    87→  }
    88→
    89→  // ===========================================================================
    90→  // Settings API
    91→  // ===========================================================================
    92→
    93→  getSettings(): Promise<Settings> {
    94→    return workspace.getSettings(this.config)
    95→  }
    96→
    97→  saveSettings(settings: Settings): Promise<void> {
    98→    return workspace.saveSettings(this.config, settings)
    99→  }
   100→
