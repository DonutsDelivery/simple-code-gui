     1→/**
     2→ * HTTP API Client
     3→ *
     4→ * Provides an HTTP/WebSocket-based API client that mirrors the electronAPI interface.
     5→ * This allows the same UI code to work with either Electron IPC or HTTP transport.
     6→ */
     7→
     8→import { HostConfig } from '../hostConfig.js'
     9→import { WebSocketManager } from './websocket-manager.js'
    10→import * as workspace from './api-workspace.js'
    11→import * as terminal from './api-terminal.js'
