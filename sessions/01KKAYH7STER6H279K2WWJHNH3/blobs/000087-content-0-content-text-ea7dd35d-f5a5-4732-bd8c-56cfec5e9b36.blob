     1→import * as pty from 'node-pty'
     2→import * as fs from 'fs'
     3→import * as path from 'path'
     4→import {
     5→  isWindows,
     6→  getEnhancedPathWithPortable,
     7→  getAdditionalPaths,
     8→} from './platform'
     9→import { getPortableBinDirs } from './portable-deps'
    10→
    11→// Backends that use Ink (React for CLI) and are sensitive to rapid resize during startup
    12→const INK_BACKENDS = new Set(['gemini'])
    13→
    14→// Ring buffer for storing recent PTY output
    15→const OUTPUT_BUFFER_MAX_LINES = 200
    16→
    17→class OutputBuffer {
    18→  private lines: string[] = []
    19→  private partial: string = '' // incomplete line (no newline yet)
    20→
    21→  append(data: string): void {
    22→    // Split incoming data by newlines, preserving partial lines
    23→    const text = this.partial + data
    24→    const parts = text.split('\n')
    25→    // Last element is either empty (if data ended with \n) or a partial line
    26→    this.partial = parts.pop() || ''
    27→    for (const line of parts) {
    28→      // Strip ANSI escape sequences for readability
    29→      const clean = line.replace(/\x1b\[[0-9;]*[a-zA-Z]/g, '').replace(/\x1b\][^\x07]*\x07/g, '').trim()
    30→      if (clean) {
    31→        this.lines.push(clean)
    32→        if (this.lines.length > OUTPUT_BUFFER_MAX_LINES) {
    33→          this.lines.shift()
    34→        }
    35→      }
    36→    }
    37→  }
    38→
    39→  getRecent(maxLines: number = 50): string[] {
    40→    return this.lines.slice(-maxLines)
    41→  }
    42→
    43→  clear(): void {
    44→    this.lines = []
    45→    this.partial = ''
    46→  }
    47→}
    48→
    49→interface ClaudeProcess {
    50→  id: string
    51→  pty: pty.IPty
    52→  cwd: string
    53→  sessionId?: string
    54→  backend?: 'claude' | 'gemini' | 'codex' | 'opencode' | 'aider'
    55→  disposables: { dispose: () => void }[]
    56→  spawnedAt: number
    57→  resizeTimeout?: ReturnType<typeof setTimeout>
    58→  lastResizeCols?: number
    59→  lastResizeRows?: number
    60→  outputBuffer: OutputBuffer
    61→}
    62→
    63→// Extended node-pty options - useConpty is a Windows-specific option not in @types/node-pty
    64→interface ExtendedPtyForkOptions extends pty.IPtyForkOptions {
    65→  useConpty?: boolean
    66→}
    67→
    68→function getEnhancedEnv(): { [key: string]: string } {
    69→  const env = { ...process.env } as { [key: string]: string }
    70→  delete env.CLAUDECODE
    71→  const enhancedPath = getEnhancedPathWithPortable()
    72→
    73→  // On Windows, environment variables are case-insensitive but we need to set the right one
    74→  if (isWindows) {
    75→    // Windows uses 'Path' but Node sometimes uses 'PATH' - set both to be safe
    76→    env.PATH = enhancedPath
    77→    env.Path = enhancedPath
    78→
    79→    // Claude Code on Windows requires git-bash - try to find and set it
    80→    if (!env.CLAUDE_CODE_GIT_BASH_PATH) {
    81→      const gitBashPaths = [
    82→        'C:\\Program Files\\Git\\bin\\bash.exe',
    83→        'C:\\Program Files (x86)\\Git\\bin\\bash.exe',
    84→        path.join(
    85→          process.env.LOCALAPPDATA || '',
    86→          'Programs',
    87→          'Git',
    88→          'bin',
    89→          'bash.exe'
    90→        ),
    91→        path.join(process.env.PROGRAMFILES || '', 'Git', 'bin', 'bash.exe'),
    92→      ]
    93→      for (const bashPath of gitBashPaths) {
    94→        if (fs.existsSync(bashPath)) {
    95→          env.CLAUDE_CODE_GIT_BASH_PATH = bashPath
    96→          console.log('Found git-bash at:', bashPath)
    97→          break
    98→        }
    99→      }
   100→    }
   101→  } else {
   102→    env.PATH = enhancedPath
   103→  }
   104→
   105→  console.log('Enhanced PATH for PTY:', enhancedPath.substring(0, 200) + '...')
   106→  return env
   107→}
   108→
   109→// Find executable for the given backend
   110→function findExecutable(
   111→  backend: 'claude' | 'gemini' | 'codex' | 'opencode' | 'aider' = 'claude'
   112→): string {
   113→  if (backend === 'gemini') {
   114→    return findGeminiExecutable()
   115→  }
   116→  if (backend === 'codex') {
   117→    return findCodexExecutable()
   118→  }
   119→  if (backend === 'opencode') {
   120→    return findOpenCodeExecutable()
   121→  }
   122→  if (backend === 'aider') {
   123→    return findAiderExecutable()
   124→  }
   125→  return findClaudeExecutable()
   126→}
   127→
   128→// Find gemini executable - on Windows, npm installs .cmd files
   129→function findGeminiExecutable(): string {
   130→  if (!isWindows) {
   131→    return 'gemini'
   132→  }
   133→
   134→  // On Windows, check for gemini.cmd in portable npm-global first
   135→  const portableDirs = getPortableBinDirs()
   136→  for (const dir of portableDirs) {
   137→    const geminiCmd = path.join(dir, 'gemini.cmd')
   138→    if (fs.existsSync(geminiCmd)) {
   139→      console.log('Found Gemini at (portable):', geminiCmd)
   140→      return geminiCmd
   141→    }
   142→  }
   143→
   144→  // Then check for gemini.cmd in system npm paths
   145→  const additionalPaths = getAdditionalPaths()
   146→  for (const dir of additionalPaths) {
   147→    const geminiCmd = path.join(dir, 'gemini.cmd')
   148→    if (fs.existsSync(geminiCmd)) {
   149→      console.log('Found Gemini at:', geminiCmd)
   150→      return geminiCmd
   151→    }
   152→  }
   153→
   154→  // Fall back to just 'gemini' and let PATH resolve it
   155→  return 'gemini'
   156→}
   157→
   158→// Find codex executable - on Windows, npm installs .cmd files
   159→function findCodexExecutable(): string {
   160→  if (!isWindows) {
   161→    return 'codex'
   162→  }
   163→
   164→  // On Windows, check for codex.cmd in portable npm-global first
   165→  const portableDirs = getPortableBinDirs()
   166→  for (const dir of portableDirs) {
   167→    const codexCmd = path.join(dir, 'codex.cmd')
   168→    if (fs.existsSync(codexCmd)) {
   169→      console.log('Found Codex at (portable):', codexCmd)
   170→      return codexCmd
   171→    }
   172→  }
   173→
   174→  // Then check for codex.cmd in system npm paths
   175→  const additionalPaths = getAdditionalPaths()
   176→  for (const dir of additionalPaths) {
   177→    const codexCmd = path.join(dir, 'codex.cmd')
   178→    if (fs.existsSync(codexCmd)) {
   179→      console.log('Found Codex at:', codexCmd)
   180→      return codexCmd
   181→    }
   182→  }
   183→
   184→  // Fall back to just 'codex' and let PATH resolve it
   185→  return 'codex'
   186→}
